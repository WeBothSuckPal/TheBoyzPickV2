# Database — get this from your Neon dashboard (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session secret — generate a random string, e.g.: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret

# The Odds API key — from https://the-odds-api.com
ODDS_API_KEY=your-odds-api-key-here

# Node environment — leave as production on the server
NODE_ENV=production

# Port — Nginx will proxy to this port; keep at 5000 unless you change nginx.conf
PORT=5000
